msgid ""
"A workspace shared folder must be selected when not using system memory."
msgstr ""
"ຕ້ອງເລືອກໂຟນເດີແບ່ງປັນສຳລັບພື້ນທີ່ເຮັດວຽກ ເມື່ອບໍ່ໄດ້ໃຊ້ໜ່ວຍຄວາມຈຳລະບົບ."

msgid "Date & Time"
msgstr "ວັນທີ ແລະ ເວລາ"

msgid "Details"
msgstr "ລາຍລະອຽດ"

msgid "Enabled"
msgstr "ເປີດໃຊ້ງານ"

msgid "Event"
msgstr "ເຫດການ"

msgid "Flush"
msgstr "ລ້າງຂໍ້ມູນ"

msgid "Flush daily"
msgstr "ລ້າງຂໍ້ມູນປະຈຳວັນ"

msgid "Flush hourly"
msgstr "ລ້າງຂໍ້ມູນທຸກໆຊົ່ວໂມງ"

msgid "Flush on boot"
msgstr "ລ້າງຂໍ້ມູນຕອນເລີ່ມລະບົບ"

msgid "Flush on shutdown"
msgstr "ລ້າງຂໍ້ມູນຕອນປິດລະບົບ"

msgid "Hour"
msgstr "ຊົ່ວໂມງ"

msgid ""
"If checked, writecache will use system memory to store changes.<br/>If "
"unchecked, writecache will store those changes in the selected shared "
"folder. Changes are not lost if the system reboots or shuts down "
"unexpectedly."
msgstr ""
"ຫາກເລືອກ, writecache "
"ຈະໃຊ້ໜ່ວຍຄວາມຈຳລະບົບເພື່ອເກັບການປ່ຽນແປງ.<br/>ຫາກບໍ່ເລືອກ, writecache "
"ຈະເກັບການປ່ຽນແປງເຫຼົ່ານັ້ນໄວ້ໃນໂຟນເດີແບ່ງປັນທີ່ເລືອກ. ຂໍ້ມູນຈະບໍ່ສູນຫາຍ "
"ຫາກລະບົບເລີ່ມໃໝ່ ຫຼື ປິດລົງຢ່າງກະທັນຫັນ."

msgid "Journal storage"
msgstr "ການເກັບຮັກສາບັນທຶກ (Journal)"

msgid "Level"
msgstr "ລະດັບ"

msgid "Minute"
msgstr "ນາທີ"

msgid "Overlay paths and policy"
msgstr "ເສັ້ນທາງ Overlay ແລະ ນະໂຍບາຍ"

msgid "Rotate & Flush"
msgstr "ໝູນວຽນ ແລະ ລ້າງຂໍ້ມູນ"

msgid "Rotate on daily flush"
msgstr "ໝູນວຽນເມື່ອລ້າງຂໍ້ມູນປະຈຳວັນ"

msgid "Rotate on shutdown"
msgstr "ໝູນວຽນເມື່ອປິດລະບົບ"

msgid "Run journalctl rotate and sync before flush"
msgstr "ເປີດໃຊ້ journalctl rotate ແລະ sync ກ່ອນລ້າງຂໍ້ມູນ"

msgid "Running manual flush ..."
msgstr "ກຳລັງລ້າງຂໍ້ມູນດ້ວຍຕົນເອງ ..."

msgid "Running manual rotate and flush ..."
msgstr "ກຳລັງໝູນວຽນ ແລະ ລ້າງຂໍ້ມູນດ້ວຍຕົນເອງ ..."

msgid "Services to reload/restart after flush"
msgstr "ບໍລິການທີ່ຈະເລີ່ມໃໝ່ຫຼັງຈາກລ້າງຂໍ້ມູນ"

msgid ""
"Size for /run/omv-writecache tmpfs. Accepts %, M/G suffix; e.g. 512M, 2G, "
"25%."
msgstr ""
"ຂະໜາດສຳລັບ /run/omv-writecache tmpfs. ຮອງຮັບ %, ຕົວອັກສອນຕໍ່ທ້າຍ M/G; "
"ຕົວຢ່າງ: 512M, 2G, 25%."

msgid "Status"
msgstr "ສະຖານະ"

msgid "Use system memory"
msgstr "ໃຊ້ໜ່ວຍຄວາມຈຳລະບົບ"

msgid "Used to store temporary writecache changes."
msgstr "ໃຊ້ເພື່ອເກັບການປ່ຽນແປງຊົ່ວຄາວຂອງ writecache."

msgid "Workspace folder"
msgstr "ໂຟນເດີພື້ນທີ່ເຮັດວຽກ"

msgid "Write Cache"
msgstr "Write Cache"

msgid "Write Cache settings"
msgstr "ການຕັ້ງຄ່າ Write Cache"

msgid "WriteCache"
msgstr "WriteCache"

msgid "auto"
msgstr "ອັດຕະໂນມັດ"

msgid "persistent (disk)"
msgstr "ຖາວອນ (ດິສກ໌)"

msgid "tmpfs size"
msgstr "ຂະໜາດ tmpfs"

msgid "volatile (RAM)"
msgstr "ຊົ່ວຄາວ (RAM)"
